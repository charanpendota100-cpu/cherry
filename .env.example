# WhatsApp Automation Pro - Environment Variables
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════
# SERVER CONFIGURATION
# ═══════════════════════════════════════════════
PORT=3001
NODE_ENV=development

# ═══════════════════════════════════════════════
# SESSION MANAGEMENT
# ═══════════════════════════════════════════════
MAX_RESTORE_SESSIONS=3
MAX_CONCURRENT_SESSIONS=10
SESSION_INACTIVITY_TIMEOUT_MINS=30

# ═══════════════════════════════════════════════
# MESSAGING LIMITS
# ═══════════════════════════════════════════════
DAILY_LIMIT=500

# ═══════════════════════════════════════════════
# CORS / FRONTEND (comma-separated origins)
# ═══════════════════════════════════════════════
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ═══════════════════════════════════════════════
# REDIS (optional - for BullMQ queue persistence)
# ═══════════════════════════════════════════════
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ═══════════════════════════════════════════════
# GEMINI AI (optional - for AI Quiz & Smart Replies)
# ═══════════════════════════════════════════════
# GEMINI_API_KEY=your_gemini_api_key_here

# ═══════════════════════════════════════════════
# SECURITY
# ═══════════════════════════════════════════════
# JWT_SECRET=change-this-to-a-random-string-min-32-characters
# ADMIN_API_KEY=change-this-admin-key
